{
  "name": "@muebles/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./seed": {
      "types": "./src/seed.ts",
      "import": "./src/seed.ts",
      "default": "./src/seed.ts"
    },
    "./jsonFileStorage": {
      "types": "./src/jsonFileStorage.ts",
      "import": "./src/jsonFileStorage.ts",
      "default": "./src/jsonFileStorage.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@muebles/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
