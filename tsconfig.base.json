{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@muebles/domain": ["./packages/domain/src/index.ts"],
      "@muebles/domain/fixtures": [
        "./packages/domain/src/__fixtures__/plantillaDemo.ts"
      ],
      "@muebles/domain/*": ["./packages/domain/src/*"],
      "@muebles/ui": ["./packages/ui/src/index.ts"],
      "@muebles/ui/*": ["./packages/ui/src/*"],
      "@muebles/excel": ["./packages/excel/src/index.ts"],
      "@muebles/excel/*": ["./packages/excel/src/*"],
      "@muebles/storage": ["./packages/storage/src/index.ts"],
      "@muebles/storage/seed": ["./packages/storage/src/seed.ts"],
      "@muebles/storage/*": ["./packages/storage/src/*"]
    }
  }
}
