# Muebles backend — example environment.
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# `.env*` is gitignored; this `.env.example` is tracked on purpose.
#
# Setup:
#   cp .env.example .env.local
#   # edita .env.local: JWT_SECRET="$(openssl rand -base64 48)"
#   cd backend-go && ./dev.sh        # arranca el server Go con estas vars

# --- Backend Go ---
PORT=8080

# --- Database ---
# Local dev default points to the docker-compose Postgres on :5445.
# Production MUST set its own DSN (ideally with sslmode=require).
DATABASE_URL=postgres://postgres:postgres@localhost:5445/muebles?sslmode=disable

# --- Security: JWT (REQUIRED) ---
# Generate with: openssl rand -base64 48
# Must be >= 32 bytes. The server refuses to boot if missing or too short.
JWT_SECRET=

# --- Security: CORS allowlist ---
# Comma-separated list of allowed origins. Never use "*" in production.
# Defaults to the Vite dev/preview servers if unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Security: rate limiting on /api/auth/login and /api/auth/register ---
# Sustained requests/second and max burst per client IP.
RATE_LIMIT_RPS=0.2
RATE_LIMIT_BURST=5

# --- Frontend (Vite, apps/web) ---
# Overrides DEFAULT_API_BASE in session.ts. Vite loads .env.local automatically.
VITE_API_BASE=http://localhost:8080/api

# --- Admin CLI (cmd/admin) ---
# Only used by `./dev.sh admin create|reset-password` in non-interactive
# mode (e.g. CI). In interactive mode the password is prompted without echo.
# ADMIN_PASSWORD=

